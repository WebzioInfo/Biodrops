// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  LAB
  INSPECTOR
  COMPANY_QC
}

enum BatchStatus {
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role     @default(COMPANY_QC)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  auditLogs AuditLog[]
}

model Company {
  id        String   @id @default(cuid())
  name      String
  licenseNo String?
  type      String   @default("MINERAL_WATER") // or "HOTEL"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  productionBatches ProductionBatch[]
}

model ProductionBatch {
  id             String      @id @default(cuid())
  batchNumber    String      @unique
  productionDate DateTime
  testDate       DateTime?
  parameters     Json?       // WaterQualityParameters stored as JSON
  status         BatchStatus @default(PENDING)
  qrCodeUrl      String?
  
  companyId      String
  company        Company     @relation(fields: [companyId], references: [id])
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  
  auditLogs      AuditLog[]
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // e.g. "BATCH_CREATED", "BATCH_VERIFIED"
  details   Json?
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  batchId   String?
  batch     ProductionBatch? @relation(fields: [batchId], references: [id])
  
  createdAt DateTime @default(now())
}
